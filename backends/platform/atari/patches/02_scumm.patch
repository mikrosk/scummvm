+
+| void ByleRLEDecode_Classic(
+|	BaseCostumeRenderer::ByleRLEData *pcompData,
+|	const byte _scaleX, /* unused */
+|	const byte _scaleY, /* unused */
+|	const int _height,
+|	const int pitch,
+|	const int _numStrips,
+|	const byte *_srcPtr,
