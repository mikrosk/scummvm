-									// applies. But this is the only way to prevent recursive shading of pixels.
-									// This might need more fine tuning...
-									skipColumn = (lastColumnX == compData.x);
-									pcolor = (pcolor << 8) + *dst;
-									pcolor = xmap[pcolor];
-								} else if (pcolor < 8) {
