+				_scaleY,
+				_height,
+				_out.pitch,
+				_numStrips,
+				_srcPtr,
+				shadowTable,
+				_palette);
+			return;
+		} else if (shadowMode == ShadowMode::Mode1) {
+			ByleRLEDecode_Mode1_YClip(
