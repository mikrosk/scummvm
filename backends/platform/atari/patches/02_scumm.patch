 					rect.left--;
 			}
+			startScaleIndexX -= linesToSkip;
 		}
 
-		if (linesToSkip)
-			linesToSkip--;
-
 		step = -1;
 		if (yMoveCur < 0) {
 			yMoveCur = -yMoveCur;
@@ -144,9 +144,18 @@ byte BaseCostumeRenderer::paintCelByleRLECommon(
 		if (_drawActorToRight) {
